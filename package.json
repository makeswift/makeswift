    "lint": "turbo run lint --filter=!./apps/*",
    "test": "turbo run test",
    "madge": "turbo run madge"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.41.1",
    "@types/node": "^20.14.8",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "turbo": "^1.13.3"
  }
}
