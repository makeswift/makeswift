{
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": "^9.15.4"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "turbo run build --filter=!./apps/*",
